# .gitignore for ats-protocol monorepo

# ── Dart/Flutter ──
**/.dart_tool/
**/build/
**/pubspec.lock

# ── Node.js/TypeScript ──
**/node_modules/
**/dist/
**/*.tsbuildinfo
**/package-lock.json

# ── ATS runtime (generated in user projects) ──
.ats/
ats.yaml
lib/generated/

# ── IDE ──
.idea/
.vscode/
*.iml
*.code-workspace

# ── OS ──
.DS_Store
**/.DS_Store
Thumbs.db

# ── Misc ──
*.log
*.tmp