# .gitignore for ats-protocol root

# Dart/Flutter packages
**/.dart_tool/
**/build/
**/pubspec.lock

# ATS runtime logs (never commit — add to user project .gitignore too)
**/.ats/logs/

# ATS flow_graph.json is intentionally COMMITTED in user projects
# Do NOT add assets/ats/flow_graph.json here

# IDE
.idea/
.vscode/
*.iml

# macOS
.DS_Store
**/.DS_Store